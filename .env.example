# 구글 AI Studio API 키 설정
#
# 1. 이 파일을 같은 폴더에 ".env" 라는 이름으로 복사하세요.
# 2. 아래 GOOGLE_API_KEY_1 ... 11 자리에 실제 API 키를 한 줄에 하나씩 붙여넣으세요.
#    (AI Studio = 프로젝트당 키 1개, 프로젝트마다 쿼터 독립 → 11개로 병렬)
#    (키 발급: https://aistudio.google.com/apikey)
#
# .env 파일은 .gitignore에 의해 깃허브에 올라가지 않습니다.

# --- 병렬용 키 풀 (한 줄에 하나, 안 쓰는 줄은 비우거나 지우면 됨) ---
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=
GOOGLE_API_KEY_6=
GOOGLE_API_KEY_7=
GOOGLE_API_KEY_8=
GOOGLE_API_KEY_9=
GOOGLE_API_KEY_10=
GOOGLE_API_KEY_11=

ARC_MAX_LIVE=11
ARC_REQUEST_TIMEOUT_SECONDS=600
ARC_JSON_MAX_OUTPUT_TOKENS=8192
ARC_PROSE_MAX_OUTPUT_TOKENS=32768
ARC_THINKING_LEVEL=high


# (하위호환) 키 1개만 쓰던 기존 방식. 위 번호 키가 하나도 없으면 이 값을 단일 풀로 사용.
# GOOGLE_API_KEY=

MODEL=gemma-4-31b-it

# 실제 값은 .env에만 넣으세요 (이 예시 파일이 아니라).
